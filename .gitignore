# Document/Research Repository .gitignore

# OS-generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# Windows
$RECYCLE.BIN/

# Temporary files
*.tmp
*.temp
*~
*.bak
*.swp
*.swo

# Microsoft Office temp files
~$*.docx
~$*.xlsx
~$*.pptx
~$*.doc
~$*.xls
~$*.ppt

# LaTeX auxiliary files
*.aux
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.log
*.out
*.synctex.gz
*.toc
*.lot
*.lof
*.nav
*.snm
*.vrb
*.bcf
*.run.xml
*-blx.bib

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.env
.venv
venv/
env/

# Jupyter Notebooks
.ipynb_checkpoints/

# R
.Rhistory
.RData
.Rproj.user/

# Build outputs
build/
dist/
*.pdf.bak

# Personal notes / drafts
drafts/
notes/
scratch/

# Credentials / secrets
*.key
*.pem
secrets/
